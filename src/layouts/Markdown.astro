---
import globalStyles from "../styles/global.css?url";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { frontmatter } = Astro.props;
let title = frontmatter.title || "Wenyu Zhao's Website";
if (Array.isArray(title)) {
    title = title.join(" / ");
}

// const faq = frontmatter.faq ? JSON.stringify(frontmatter.faq) : null;
const faq = null;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
        <meta name="author" content="Wenyu Zhao" />
        <meta
            name="description"
            content={frontmatter.description || "Wenyu Zhao's website"}
        />

        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.ico" />

        <link rel="preload" href={globalStyles} as="style" />
        <link rel="stylesheet" href={globalStyles} />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        {faq && <script type="application/ld+json" set:html={faq} is:inline />}
    </head>
    <body>
        <Header title={frontmatter.title} />

        <article>
            <slot />
        </article>

        <Footer />
    </body>
</html>
